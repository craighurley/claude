      "Bash(rm -r -f ~)",
      "Bash(rm -r -f $HOME:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf /Users/hurley:*)",
      "Bash(rm -rf /Users/hurley)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME:*)",
      "Bash(security:*)",
      "Bash(su:*)",
      "Bash(sudo:*)",
      "Bash(vmmap:*)",
      "Read(.vscode/**)",
      "Read(*.claude.json)",
      "Read(**/.secrets/**)",
      "Read(**/*.keychain)",
      "Read(**/1password/**)",
      "Read(**/1Password/**)",
      "Read(**/secrets/**)",
      "Read(//System/Library/**)",
      "Read(//Users/hurley/.claude.json)",
