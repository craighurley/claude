  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "~/tmp"
      ]
    },
    "network": {
      "allowedDomains": [
        "*.anthropic.com",
        "*.apple.com",
        "*.astral.sh",
        "*.context7.com",
        "*.docker.com",
        "*.docker.io",
        "*.ghcr.io",
        "*.github.com",
        "*.github.io",
        "*.githubusercontent.com",
        "*.golang.org",
        "*.nodejs.org",
        "*.npmjs.com",
        "*.npmjs.org",
        "*.pypi.org",
        "*.schemastore.org",
        "*.search.brave.com",
        "*.wikipedia.org",
        "*.youtube.com",
        "*.youtu.be",
        "ghcr.io",
        "google.com.au",
        "google.com",
        "pypi.org",
        "swift.org"
      ],
      "allowLocalBinding": true
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working"
    ]
  }
}
