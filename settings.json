      "Bash(realpath:*)",
      "Bash(rg:*)",
      "Bash(rgrep:*)",
      "Bash(run_silent:*)",
      "Bash(rustfmt:*)",
      "Bash(sed:*)",
      "Bash(shellcheck:*)",
      "Bash(sort:*)",
      "Bash(source .venv/bin/activate)",
      "Bash(source venv/bin/activate)",
      "Bash(sqlite:*)",
      "Bash(sqlite3:*)",
      "Bash(stat:*)",
